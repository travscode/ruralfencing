{% extends 'base.twig' %}

{% block content %}
    <article class="py-16 lg:py-20">
        <div class="site-width">
            <header class="max-w-3xl border-b border-stone-200 pb-8">
                <p class="text-sm uppercase tracking-[0.2em] text-stone-500">{{ post.post_type }}</p>
                <h1 class="mt-3 text-4xl font-semibold tracking-tight text-stone-900">{{ post.title }}</h1>
                <p class="mt-4 text-sm text-stone-500">{{ post.date }}</p>
            </header>
            <div class="rich-text mt-8 max-w-3xl">
                {{ post.content }}
            </div>
        </div>
    </article>
{% endblock %}
