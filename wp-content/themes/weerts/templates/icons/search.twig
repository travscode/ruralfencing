		stroke="currentColor"
		stroke-width="2"
		stroke-linecap="square"
		stroke-linejoin="round"
	/>
	<path
		d="M15 15L11.6167 11.6167"
		stroke="currentColor"
		stroke-width="2"
		stroke-linecap="round"
		stroke-linejoin="round"
	/>
</svg>
