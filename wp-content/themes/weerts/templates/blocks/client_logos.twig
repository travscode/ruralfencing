<section logo-block class="!py-0 bg-bgLight">
	<div class="container">
		<div class="border-x md:border-b border-borderLight">
			{% if block.logo_rows %}
				{% set all_logos = [] %}
				{% for row in block.logo_rows %}
					{% if row.logos %}
						{% for logo_item in row.logos %}
							{% if logo_item.logo %}
								{% set all_logos = all_logos|merge([logo_item]) %}
							{% endif %}
						{% endfor %}
					{% endif %}
				{% endfor %}

				{# Display first 2 rows of 6 logos each (12 total) #}
				{% for i in 0..1 %}
					<div class="grid grid-cols-3 md:grid-cols-6 {{ i < 1 ? 'md:border-b' }} border-borderLight">
						{% for j in 0..5 %}
							{% set logo_index = (i * 6) + j %}
							{% set visible_logo = all_logos[logo_index] %}

							<div
								class="p-6 flex items-center justify-center {{ j < 5 ? 'md:border-r' }} {{ (j + 1) % 3 == 0 ? '' : 'max-md:border-r' }} border-borderLight max-md:border-b relative w-full overflow-hidden" data-logo-slot="{{ logo_index }}">
								{# Visible logo #}
								<div class="relative">
									{% if visible_logo %}
										<img src="{{ get_image(visible_logo.logo).src }}" alt="{{ visible_logo.logo.alt|default(visible_logo.logo.post_title) }}" class="max-w-full max-h-16 object-contain visible-logo">
									{% endif %}

									{# Additional logos for this slot (absolutely positioned) #}
									{% set slot_additional_logos = [] %}
									{% for k in 12..(all_logos|length - 1) %}
										{% if (k - 12) % 12 == logo_index %}
											{% set slot_additional_logos = slot_additional_logos|merge([all_logos[k]]) %}
										{% endif %}
									{% endfor %}

									{% for additional_logo in slot_additional_logos %}
										<img src="{{ get_image(additional_logo.logo).src }}" alt="{{ additional_logo.logo.alt|default(additional_logo.logo.post_title) }}" class="max-w-full max-h-16 object-contain absolute inset-0 m-auto additional-logo" data-logo-cycle="{{ loop.index0 }}">
									{% endfor %}
								</div>
							</div>
						{% endfor %}
					</div>
				{% endfor %}
			{% endif %}
		</div>
	</div>
</section>
