<div class="container bg-bgLight">
	<div class="border-b border-x border-borderLight flex flex-col px-6 py-6 md:py-12 gap-8 md:gap-12">
		<div class="flex flex-row">
			<div class="lg:w-1/2">
				<div class="block-content relative indent-6 max-w-[670px]">
					<span class="absolute left-0.5 top-3 xl:top-5 2xl:top-6" aria-hidden="true">
						{{ include('icons/heading-dot.twig') }}
					</span>
					{{ block.heading }}
				</div>
			</div>
		</div>
		<div class="flex flex-row lg:justify-end">
			<div class="lg:w-1/2">
				<div class="block-content max-w-[670px]">
					{{ block.content }}
				</div>
			</div>
		</div>
	</div>
</div>
