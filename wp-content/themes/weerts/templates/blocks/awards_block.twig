{% set ceremonies = function('get_terms', {
    taxonomy:   'award-ceremony',
    hide_empty: true
}) %}

{% set awards = function('get_posts', {
    'post_type': 'award',
    'posts_per_page': -1,
    'post_status': 'publish',
    'orderby': 'date',
    'order': 'DESC'
}) %}

{# Create a simple array to track years and awards #}
{% set years_data = [] %}
{% set processed_years = [] %}

{% for award in awards %}
	{% set award_years = function('get_the_terms', award.ID, 'award-year') %}
	{% set current_year = award_years and award_years[0] ? award_years[0].name : 'Unknown' %}

	{# Check if we've already processed this year #}
	{% if current_year not in processed_years %}
		{% set processed_years = processed_years|merge([current_year]) %}

		{# Get all awards for this year #}
		{% set year_awards = [] %}
		{% for check_award in awards %}
			{% set check_award_years = function('get_the_terms', check_award.ID, 'award-year') %}
			{% set check_year = check_award_years and check_award_years[0] ? check_award_years[0].name : 'Unknown' %}
			{% if check_year == current_year %}
				{% set year_awards = year_awards|merge([check_award]) %}
			{% endif %}
		{% endfor %}

		{% set years_data = years_data|merge([{
            'year': current_year,
            'awards': year_awards
        }]) %}
	{% endif %}
{% endfor %}

<div class="awards-block bg-bgLight container">
	<div class="border-x border-b border-borderLight flex lg:flex-row flex-col">
		<div class="lg:w-1/2 w-full md:border-r border-borderLight flex flex-col justify-between">
			<div class="accordion w-full">
				{% for year_data in years_data %}
					<div class="accordion-header flex justify-between md:items-center w-full p-6 cursor-pointer">
						<div class="flex">
							<h4 class="text-3xl font-medium text-textDark">{{ year_data.year }}</h4>
						</div>
						<span class="menu-plus transition-all duration-200 flex items-center">
							{% include 'icons/plus.twig' with { class: 'size-2.5' } %}
						</span>
					</div>
					<div class="accordion-content overflow-hidden border-t border-borderLight">
						<div class="accordion-inner">
							{% for award in year_data.awards %}
								{% set work_post = function('get_field', 'work', award.ID) %}
								{% set award_categories = function('get_the_terms', award.ID, 'award-category') %}
								{% set award_ceremonies = function('get_the_terms', award.ID, 'award-ceremony') %}
								{% set work_url = work_post ? function('get_permalink', work_post.ID) : '#' %}
								{% set work_title = work_post ? work_post.post_title : 'N/A' %}

								<div class="{{ not loop.first ? 'border-t ' }} border-borderLight hover:bg-gray-50 transition-colors flex flex-row">
									<span class="p-0 w-1/3">
										<a href="{{ work_url }}" class="block px-6 py-3 w-full h-full">
											{{ work_title }}
										</a>
									</span>
									<span class="p-0 w-1/3">
										<a href="{{ work_url }}" class="block px-6 py-3 w-full h-full text-sm">
											{{ award.post_title }}
										</a>
									</span>
									<span class="p-0 w-1/3">
										<a href="{{ work_url }}" class="block px-6 py-3 w-full h-full text-sm">
											{{ award_ceremonies and award_ceremonies[0] ? award_ceremonies[0].name : 'N/A' }}
										</a>
									</span>
								</div>
							{% endfor %}
						</div>
					</div>
				{% endfor %}
			</div>
			{% if block.button %}
				<div class="p-6 md:border-t border-borderLight">
					{% include "partials/button.twig" with { link: block.button.url, title: block.button.title, target: block.button.target } %}
				</div>
			{% endif %}

		</div>
		<div class="lg:w-1/2 w-full flex lg:flex-row flex-col border-t border-borderLight lg:border-none">
			{% if block.image_1 %}
				<div class="image p-6 flex flex-col gap-6 w-full first-letter:lg:w-1/2 border-b lg:border-b-0 lg:border-r border-borderLight">
					<div class="relative">
						<img src="{{ block.image_1.src }}" alt="{{ block.image_1.alt|default(block.image_1.post_title) }}" class="w-full h-auto">
					</div>
					<div class="flex flex-row justify-between items-center">
						<p>{{ block.caption_1 }}</p>
						<p class="text-textDarkSubtle">{{ block.caption_1_subtle }}</p>
					</div>
				</div>
			{% endif %}
			{% if block.image_2 %}
				<div class="image flex p-6 flex-col gap-6 w-full first-letter:lg:w-1/2">
					<div class="relative">
						<img src="{{ block.image_2.src }}" alt="{{ block.image_2.alt|default(block.image_2.post_title) }}" class="w-full h-auto">
					</div>
					<div class="flex flex-row justify-between items-center">
						<p>{{ block.caption_2 }}</p>
						<p class="text-textDarkSubtle">{{ block.caption_2_subtle }}</p>
					</div>
				</div>
			{% endif %}
		</div>
	</div>
</div>
