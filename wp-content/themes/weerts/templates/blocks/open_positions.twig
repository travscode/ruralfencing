{# Import macro for rendering table cells #}
{% import _self as Table %}

{% macro cell(item, field) %}
	{% set value = attribute(item, field) %}
	{% set url   = item.job_application_url %}
	{% if url %}
		<a href="{{ url }}" class="flex w-full h-full group-hover:text-bgLight duration-300 ease-fancy relative z-20">
			<span class="scramble-part">
				{{ value }}</span>
		</a>
	{% else %}
		<div class="flex w-full h-full group-hover:text-bgLight duration-300 ease-fancy relative z-20">
			<span class="scramble-part">
				{{ value }}
			</span>
		</div>
	{% endif %}
{% endmacro %}

{# Fetch and only render if there are any positions #}
{% set open_positions = function('get_posts', {
  post_type      : 'open-position',
  posts_per_page : -1,
  post_status    : 'publish',
  orderby        : 'date',
  order          : 'DESC'
}) %}

{% if open_positions %}
	<div class="bg-bgLight container">
		<div class=" border-b border-borderLight border-x">
			<div class="heading-container flex flex-row gap-3 p-6 bg-bgLight border-b border-borderLight">
				<span class="mb-2 mt-auto">{% include 'icons/heading-dot.twig' %}</span>
				<span class="is-h2">Open positions</span>
				<div>
					<span class="text-sm">
						{{ open_positions|length }}
					</span>
				</div>
			</div>
			<div class="flex justify-end">
				<div class="w-full lg:w-3/4 lg:border-l border-borderLight">
					<div class="w-full">
						{% for pos in open_positions %}
							<div class="{{ not loop.last ? 'border-b border-borderLight' }} group flex max-sm:flex-col scramble-inner relative p-6 gap-2 z-20">
								{{ Table.cell(pos, 'post_title') }}
								{{ Table.cell(pos, 'employment_type') }}
								{{ Table.cell(pos, 'work_arrangement') }}
								<div class="absolute w-full h-0 left-0 bottom-0 bg-black duration-300 ease-fancy group-hover:h-full"></div>
							</div>
						{% endfor %}
						
						{# Add accordion for Open Position Form #}
						<div class="border-b transition-color border-borderLight last:border-b-0 {% if open_positions|length > 0 %} border-t {% endif %}">
							<div class="accordion-header flex justify-between md:items-center w-full p-6 cursor-pointer">
								<div class="flex gap-4">
									<h4 class="text-xl font-medium text-textDark">Open Position Form</h4>
								</div>
								<span class="menu-plus transition-all duration-300 flex items-center">
									{% include 'icons/plus.twig' with { class: 'size-2.5' } %}
								</span>
							</div>
							<div class="accordion-content overflow-hidden">
								<div class="accordion-inner ">
									<div class="p-6 open-form">
										{% apply shortcodes %}
											[gravityform id="3" title="false" ajax="true"]
										{% endapply %}
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
{% endif %}
