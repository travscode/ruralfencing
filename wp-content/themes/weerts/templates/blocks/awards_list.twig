{# TODO: Hover state - will match whatever you do on the homepage WEBBY #}

{% set awards = function('get_posts', {
    'post_type': 'award',
    'posts_per_page': -1,
    'post_status': 'publish',
    'orderby': 'date',
    'order': 'DESC'
}) %}
<div class="container bg-bgLight">
    <div class="border-b border-borderLight border-x">
        <div class="w-full">
            {% if awards|length > 0 %}
                <table class="w-full border-collapse table-fixed">
                    <tbody>
                        {% set previous_year = '' %}
                        {% for award in awards %}
                            {% set work_post = function('get_field', 'work', award.ID) %}
                            {% set award_years = function('get_the_terms', award.ID, 'award-year') %}
                            {% set award_categories = function('get_the_terms', award.ID, 'award-category') %}
                            {% set award_ceremonies = function('get_the_terms', award.ID, 'award-ceremony') %}
                            {% set work_url = work_post ? function('get_permalink', work_post.ID) : '#' %}
                            {% set work_title = work_post ? work_post.post_title : 'N/A' %}
                            {% set current_year = award_years and award_years[0] ? award_years[0].name : 'Unknown' %}
                            {% set show_year = current_year != previous_year %}
                            <tr class="{{ not loop.last ? 'border-b border-borderLight' }} hover:bg-gray-50 transition-colors">
                                <td class="p-0 w-1/4">
                                    <a href="{{ work_url }}" class="block p-3 w-full h-full">
                                        {{ show_year ? current_year : '' }}
                                    </a>
                                </td>
                                <td class="p-0 w-1/4">
                                    <a href="{{ work_url }}" class="block p-3 w-full h-full">
                                        {{ work_title }}
                                    </a>
                                </td>
                                <td class="p-0 w-1/4">
                                    <a href="{{ work_url }}" class="block p-3 w-full h-full">
                                        {{ award_categories and award_categories[0] ? award_categories[0].name : 'N/A' }}
                                    </a>
                                </td>
                                <td class="p-0 w-1/4">
                                    <a href="{{ work_url }}" class="block p-3 w-full h-full">
                                        {{ award_ceremonies and award_ceremonies[0] ? award_ceremonies[0].name : 'N/A' }}
                                    </a>
                                </td>
                            </tr>
                            {% set previous_year = current_year %}
                        {% endfor %}
                    </tbody>
                </table>
            {% else %}
                <div class="p-6 text-center text-gray-500">
                    No awards found. Please create some award posts in the WordPress admin.
                </div>
            {% endif %}
        </div>
    </div>
    {% include "partials/home/spacer.twig" %}
</div>