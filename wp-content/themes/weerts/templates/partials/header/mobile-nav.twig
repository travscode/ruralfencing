		<div class="mobile-accordion-item" data-mobile-accordion>
			<div class="accordion-header flex justify-between items-center w-full">
				<span class="menu-heading is-h4">Design</span>
				<span class="menu-plus transition-all">{% include 'icons/plus.twig' with { class: 'size-2.5' } %}</span>
			</div>
			<div class="accordion-content overflow-hidden">
				<ul class="flex flex-col gap-2 mt-4">
					{% for item in design_menu.get_items %}
