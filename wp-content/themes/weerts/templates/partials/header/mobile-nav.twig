							<a href="{{ item.link }}" target="{{ item.target }}" class="menu-item scramble-text font-mono text-sm uppercase pointer-events-auto">{{ item.title }}</a>
						</li>
					{% endfor %}
				</ul>
			</div>
		</div>
	</div>

	<div class="menu-column border-b w-full flex flex-col p-6 gap-6">
