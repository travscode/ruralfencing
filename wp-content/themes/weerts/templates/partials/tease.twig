<article class="rounded-xl border border-stone-200 bg-white p-6 shadow-sm">
    <p class="text-sm text-stone-500">{{ post.date }}</p>
    <h2 class="mt-2 text-2xl font-semibold tracking-tight text-stone-900">
        <a class="no-underline hover:text-stone-700" href="{{ post.link }}">{{ post.title }}</a>
    </h2>
    {% if post.preview %}
        <p class="mt-4 text-stone-600">{{ post.preview.read_more('') }}</p>
    {% endif %}
</article>
