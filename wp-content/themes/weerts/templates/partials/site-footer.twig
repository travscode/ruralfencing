<footer class="border-t border-stone-200 bg-white">
    <div class="site-width flex flex-col gap-6 py-8 text-sm text-stone-500 lg:flex-row lg:items-center lg:justify-between">
        <p>&copy; {{ 'now'|date('Y') }} {{ site.name }}</p>
        {% if footer_menu and footer_menu.items %}
            <nav aria-label="Footer navigation">
                <ul class="flex flex-wrap gap-4">
                    {% for item in footer_menu.items %}
                        <li>
                            <a class="no-underline hover:text-stone-900" href="{{ item.link }}" target="{{ item.target }}">{{ item.title }}</a>
                        </li>
                    {% endfor %}
                </ul>
            </nav>
        {% endif %}
    </div>
</footer>
