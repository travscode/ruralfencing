{% if pagination and pagination.pages %}
    <nav class="mt-10 flex flex-wrap items-center gap-3 text-sm text-stone-600" aria-label="Pagination">
        {% if pagination.prev %}
            <a class="rounded border border-stone-300 px-3 py-2 no-underline hover:border-stone-900 hover:text-stone-900" href="{{ pagination.prev.link }}">Previous</a>
        {% endif %}
        {% for page in pagination.pages %}
            {% if page.link %}
                <a class="rounded border border-stone-300 px-3 py-2 no-underline hover:border-stone-900 hover:text-stone-900" href="{{ page.link }}">{{ page.title }}</a>
            {% else %}
                <span class="rounded border border-stone-900 bg-stone-900 px-3 py-2 text-stone-50">{{ page.title }}</span>
            {% endif %}
        {% endfor %}
        {% if pagination.next %}
            <a class="rounded border border-stone-300 px-3 py-2 no-underline hover:border-stone-900 hover:text-stone-900" href="{{ pagination.next.link }}">Next</a>
        {% endif %}
    </nav>
{% endif %}
