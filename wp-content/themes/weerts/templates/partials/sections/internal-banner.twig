{% set section_title = title|default('') %}
{% set background = background_url|default('') %}

<section class="relative overflow-hidden px-6 py-[140px] lg:px-[100px] lg:pb-[100px] lg:pt-[243px]">
	
	<div class="absolute inset-0 bg-cover bg-center" style="background-image: url('{{ background }}');"></div>
	<div class="absolute inset-0 bg-black/40"></div>
	<div class="relative z-10  mx-auto flex w-full max-w-[1720px] flex-col gap-[70px]">
		<div class="relative ">
			<h1 class="font-heading text-d1 uppercase leading-[6.625rem] text-white max-md:text-d1-md max-md:leading-[5rem]">
				{{ section_title }}
			</h1>
		</div>
	</div>
</section>
