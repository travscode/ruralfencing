<section class="bg-eggshell px-6 pb-[180px] lg:px-[100px]">
	<div class="mx-auto w-full max-w-[1720px]">
		<div class="flex flex-col gap-10 lg:flex-row lg:gap-[165px]">
			<div class="w-full lg:w-[850px]">
				<div class="relative overflow-hidden rounded-xl bg-white">
					{% if product_badge %}
						<span class="absolute left-[18px] top-[18px] z-10 rounded-md border border-white/50 bg-goldenrod px-4 py-[10px] text-t7 leading-[23px] text-cinder">{{ product_badge }}</span>
					{% endif %}

					{% if image_url %}
						<img class="h-[420px] w-full object-cover lg:h-[600px]" src="{{ image_url }}" alt="" />
					{% endif %}
				</div>
			</div>

			<div class="w-full lg:w-[705px]">
				<div class="flex flex-col gap-10">
					<div class="flex flex-col gap-6">
						{% if sku %}
							<p class="text-t1 leading-[26px] text-deep-green">SKU: {{ sku }}</p>
						{% endif %}

						<h1 class="font-heading text-d2 uppercase leading-[58px] text-birch">{{ title }}</h1>
					</div>

					<div class="h-1 w-10 bg-deep-green"></div>

					<div class="flex items-center gap-3">
						{% if sale_price_html and regular_price_html %}
							<p class="text-[28px] leading-[30px] text-terracotta-clay line-through">{{ regular_price_html|raw }}</p>
							<p class="text-[28px] font-bold leading-[30px] text-terracotta-clay">{{ sale_price_html|raw }}</p>
						{% else %}
							<p class="text-[28px] font-bold leading-[30px] text-terracotta-clay">{{ price_html|raw }}</p>
						{% endif %}
					</div>

					{% if variation_ui %}
						<div class="flex flex-col gap-6">
							<p class="text-t4 font-bold leading-[30px] text-birch">Select a {{ variation_ui.label|lower }}:</p>

							<div class="flex flex-wrap gap-3" data-variation-attribute="{{ variation_ui.name }}">
								{% for opt in variation_ui.buttons %}
									<button
										type="button"
										class="rounded-md border border-birch px-3 py-3 text-b1 text-birch transition-colors hover:border-deep-green hover:text-deep-green"
										data-variation-value="{{ opt.value }}"
									>
										{{ opt.label }}
									</button>
								{% endfor %}
							</div>
						</div>
					{% endif %}

					<div class="flex flex-col gap-5 pt-5 lg:flex-row lg:items-center lg:gap-9">
						{% if enquire_only %}
							<button
								class="inline-flex overflow-hidden rounded-md no-underline"
								type="button"
								data-enquiry-open
							>
								<span class="flex items-center bg-goldenrod px-[26px] py-7 text-birch" aria-hidden="true">
									{% include 'icons/phone.twig' with { class: 'h-6 w-6' } %}
								</span>
								<span class="flex items-center bg-white py-8 pl-[30px] pr-[60px] font-heading text-b3 uppercase tracking-button text-birch">Product Enquiry</span>
							</button>
						{% else %}
							{{ add_to_cart_html|raw }}
							<a class="rounded-md border border-birch px-3 py-3 text-b1 text-birch no-underline transition-colors hover:border-deep-green hover:text-deep-green" href="{{ site.url }}/contact/">Or Contact Us</a>
						{% endif %}
					</div>

					<div class="flex flex-col">
						<details class="border-t border-birch py-9">
							<summary class="flex cursor-pointer list-none items-center justify-between font-heading text-d3 uppercase leading-[38px] text-birch">
								<span>Product Details</span>
								<span class="text-goldenrod">{% include 'icons/faq-plus.twig' with { class: 'h-5 w-5' } %}</span>
							</summary>
							<div class="mt-6 text-t1 leading-[26px] text-birch">
								{{ product.get_description|wpautop }}
							</div>
						</details>

						<details class="border-t border-birch py-9">
							<summary class="flex cursor-pointer list-none items-center justify-between font-heading text-d3 uppercase leading-[38px] text-birch">
								<span>Specifications</span>
								<span class="text-goldenrod">{% include 'icons/faq-plus.twig' with { class: 'h-5 w-5' } %}</span>
							</summary>
							<div class="mt-6 text-t1 leading-[26px] text-birch">
								{% if spec_lines and spec_lines|length %}
									<ul class="flex flex-col gap-3">
										{% for line in spec_lines %}
											<li><strong>{{ line.name }}:</strong> {{ line.value }}</li>
										{% endfor %}
									</ul>
								{% else %}
									<p>No specifications listed.</p>
								{% endif %}
							</div>
						</details>

						<details class="border-y border-birch py-9">
							<summary class="flex cursor-pointer list-none items-center justify-between font-heading text-d3 uppercase leading-[38px] text-birch">
								<span>Pick up &amp; Delivery</span>
								<span class="text-goldenrod">{% include 'icons/faq-plus.twig' with { class: 'h-5 w-5' } %}</span>
							</summary>
							<div class="mt-6 text-t1 leading-[26px] text-birch">
								<p>Pick up is available from our store. Delivery options may vary by product size and location.</p>
							</div>
						</details>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
