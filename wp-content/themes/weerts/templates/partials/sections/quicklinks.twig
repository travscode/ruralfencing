{% set eyebrow = eyebrow|default('') %}
{% set section_title = title|default('') %}
{% set cards = cards|default([]) %}

<section class="bg-white px-6  lg:px-[90px]">
	<div class="mx-auto flex w-full max-w-[1740px] flex-col items-center gap-[60px] py-[140px] pb-[180px]">
		<div class="flex w-full items-center justify-center gap-10">
			{% include 'icons/horiz-line.twig' with { class: 'h-1 w-10 text-deep-green' } %}
			<div>
				{% if eyebrow %}
					<p class="text-t7 uppercase tracking-button text-deep-green">{{ eyebrow }}</p>
				{% endif %}
				<h2 class="font-heading text-d2 uppercase leading-[58px] text-birch">{{ section_title }}</h2>
			</div>
		</div>

		<div class="grid w-full gap-5 lg:grid-cols-3">
			{% for card in cards %}
				<a class="group block no-underline" href="{{ card.href|default('#') }}">
					<div class="overflow-hidden rounded-xl">
						<img class="h-[260px] w-full object-cover transition-transform duration-200 group-hover:scale-[1.02] lg:h-[315px]" src="{{ card.image_url }}" alt="" />
					</div>
					<div class="mt-[10px] flex rounded-xl bg-eggshell">
						<div class="flex items-center bg-goldenrod p-[19px] text-birch">
							{% include 'icons/arrow-right.twig' with { class: 'h-3 w-3' } %}
						</div>
						<div class="flex-1 px-6 py-10">
							<h3 class="font-heading text-d3 uppercase leading-[38px] text-birch">{{ card.title }}</h3>
							<p class="mt-6 text-t1 leading-[26px] text-birch">{{ card.text }}</p>
						</div>
					</div>
				</a>
			{% endfor %}
		</div>
	</div>
</section>
