{# Question Container #}
<div id="question-container" class="text-center py-4">
	<div class="flex items-center justify-center mb-4">
		<button id="back-btn" class="back-btn text-white/40 hover:text-white transition-colors mr-4" onclick="previousStep()">
			<svg class="w-4 h-4" fill="none" stroke="currentColor" viewbox="0 0 24 24">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
			</svg>
		</button>
		<span class="label text-white/40 back-label">Back</span>
	</div>
	<h2 id="question-title" class="text-3xl text-white mb-6 font-normal"></h2>
	<div id="question-content" class="space-y-4"></div>
	<div id="question-actions" class="mt-8 flex justify-center gap-4"></div>
</div>
