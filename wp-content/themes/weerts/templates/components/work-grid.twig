<div class="our-work bg-bgLight  {{ no_container ? '' : 'container' }}">
	{% if show_filter_bar is not defined or show_filter_bar %}
		{# FILTER BAR #}
		<div class="filter-bar w-full border-b border-x border-borderLight justify-end flex flex-row flex-wrap gap-2 px-6 py-4">
			<div data-filter="all" class="filter-btn scramble-text-parent border rounded-full px-3 py-1 text-[13px] cursor-pointer pointer-events-auto transition-colors duration-200">
				<span class="scramble-text font-mono cursor-pointer uppercase">
					All
				</span>
			</div>
			{% for category in get_terms({'taxonomy': 'work-category', 'hide_empty': true}) %}
				<div data-filter="{{ category.slug }}" class="filter-btn scramble-text-parent border border-borderLight rounded-full px-3 py-1 text-[13px] text-textDark cursor-pointer pointer-events-auto transition-colors duration-200">
					<span class="scramble-text font-mono cursor-pointer uppercase">
						{{ category.name }}
					</span>
				</div>
			{% endfor %}
		</div>
	{% endif %}

	<div class="filter-items grid grid-flow-dense grid-cols-2 lg:grid-cols-4 {{ (show_filter_bar is not defined or show_filter_bar) ? 'border-x' : 'border-l border-t' }} border-borderLight">
		{% for item in work_items %}
			{% set isWide = (item.width ?? 1) == 2 %}
			{% set spanClass = isWide ? 'col-span-2' : '' %}
			{% set ratioClass = isWide ? 'aspect-[2] lg:h-[calc((100vw/4)-3.075rem)]' : 'aspect-square' %}

			{% set slugs = [] %}
			{% for term in function('wp_get_post_terms', item.project.id, 'work-category') %}
				{% set slugs = slugs|merge([term.slug]) %}
			{% endfor %}
			{% set categoryList = slugs|join(' ') %}
			{% set isComingSoon = item.project.meta('coming_soon') %}

			{# Calculate if this item is in the last row #}
			{% set totalItems = work_items|length %}
			{% set currentIndex = loop.index0 %}
			{% set colsPerRow = 4 %}
			{# lg:grid-cols-4 #}
			{% set currentRow = (currentIndex / colsPerRow)|round(0, 'floor') %}
			{% set totalRows = ((totalItems - 1) / colsPerRow)|round(0, 'floor') %}
			{% set isLastRow = currentRow == totalRows %}

			<{{isComingSoon?'div':'a'}} {{ isComingSoon ? '' : 'href="'~ item.project.link ~'"' }} class="portfolio-item filter-item h-auto relative group overflow-hidden border-b border-r border-borderLight p-4 flex flex-col gap-3 {{ spanClass }} {{ isComingSoon ? 'cursor-default' : 'cursor-pointer' }}" data-categories="{{ categoryList }}" data-mouse-content="{{ item.project.title }}">
				{% if item.image and item.video_or_image == 'image' %}
					<div class="relative {{ ratioClass }} overflow-hidden">
						<img src="{{ Image(item.image).src }}" alt="{{ Image(item.image).alt }}" class="absolute inset-0 w-full h-full object-cover">
					</div>
				{% endif %}

				{% if item.video and item.video_or_image == 'video' %}
					<div class="relative {{ ratioClass }} overflow-hidden pointer-events-none">
						{% if item.thumbnail %}
							<img src="{{ Image(item.thumbnail).src }}" alt="{{ Image(item.thumbnail).alt }}" class="absolute inset-0 w-full h-full object-cover pointer-events-none">
						{% endif %}
						<video src="{{ item.video.src }}" class="absolute inset-0 w-full h-full object-cover" autoplay muted loop playsinline>
							Your browser does not support the video tag.
						</video>
					</div>
				{% endif %}

				{% if isComingSoon %}
					<span class="is-supertitle text-bgLight bg-textDark border-white/20 border rounded-full py-2 px-4 absolute top-8 right-8 z-20 max-md:hidden">Coming soon</span>
				{% endif %}

			</{{isComingSoon?'div':'a'}}>
		{% endfor %}
	</div>
</div>
