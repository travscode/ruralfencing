			href: site.url ~ '/product-category/irrigation/'
		}
	] %}

	{% include 'partials/sections/internal-banner.twig' with {
		title: post.title,
		background_url: theme_uri ~ '/images/about-banner-bg.png'
	} only %}

	{% include 'partials/sections/location-block.twig' with {
		title: 'Visit Us in Store',
		location: {
			address: '2 Davison Street, Maddington WA 6109',
			directions_url: 'https://maps.google.com/?q=2+Davison+Street,+Maddington+WA+6109'
		},
		hours: [
			'Monday to Friday: 7:30am - 4:30pm',
			'Saturday: 8am - 1pm'
		],
		contact: {
			email: 'sales@ruralfencingsupplies.com.au',
			phone: '(08) 9492 0500',
			phone_link: '0894920500'
		}
	} only %}

	{% include 'partials/sections/text-image.twig' with {
		lead: 'Rural Fencing & Irrigation Supplies is a family company that provides excellent customer service and has the provision of up to date and technically advanced products as its main aim.',
