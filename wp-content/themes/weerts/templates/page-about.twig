	] %}

	{% set quicklink_cards = [
		{
			title: 'Fencing Supplies & Enclosures',
			text: 'Vivamus elementum semper nisi. Aenean vulputate eleifend tellus. Aenean leo ligula, porttitor eu, consequat vitae, eleifend ac, enim.',
