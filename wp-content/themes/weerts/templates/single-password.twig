{% extends 'base.twig' %}

{% block content %}
    <section class="py-16 lg:py-20">
        <div class="site-width">
            <div class="max-w-md rounded-lg border border-stone-200 bg-white p-6 shadow-sm">
                <h1 class="text-2xl font-semibold text-stone-900">Protected content</h1>
                <form class="mt-6 flex flex-col gap-4" action="{{ function('site_url', 'wp-login.php?action=postpass', 'login_post') }}" method="post">
                    <label class="text-sm font-medium text-stone-700" for="pwbox-{{ post.ID }}">Password</label>
                    <input class="rounded border border-stone-300 px-4 py-3" id="pwbox-{{ post.ID }}" name="post_password" placeholder="Enter password" type="password" />
                    <button class="inline-flex rounded bg-stone-900 px-5 py-3 text-sm font-medium text-stone-50" type="submit">Submit</button>
                </form>
            </div>
        </div>
    </section>
{% endblock %}
