{% extends 'base.twig' %}

{% block content %}
    <section class="py-20 lg:py-28">
        <div class="site-width">
            <p class="text-sm uppercase tracking-[0.2em] text-stone-500">404</p>
            <h1 class="mt-4 text-4xl font-semibold tracking-tight text-stone-900">Page not found.</h1>
            <p class="mt-6 max-w-2xl text-lg leading-8 text-stone-600">The page you were looking for does not exist or has moved.</p>
            <a class="mt-8 inline-flex rounded bg-stone-900 px-5 py-3 text-sm font-medium text-stone-50 no-underline hover:bg-stone-700" href="{{ site.link }}">Back home</a>
        </div>
    </section>
{% endblock %}
